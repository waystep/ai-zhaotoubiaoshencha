# Database
DATABASE_URL=postgresql://user:password@localhost:5432/smart_tender_review

# NextAuth
AUTH_SECRET=your-auth-secret-here
AUTH_URL=http://localhost:3000

# 忘记密码邮件（可选，使用 Resend：https://resend.com）
# RESEND_API_KEY=re_xxxx
# RESEND_FROM_EMAIL=平台名 <onboarding@resend.dev>

# OAuth Providers (optional)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# MinerU API Configuration (本地部署)
# MinerU 本地部署后的 API 地址，默认 http://127.0.0.1:8000
MINERU_API_URL=http://127.0.0.1:8000
# MinerU API Key（可选，部分部署可能需要认证）
MINERU_API_KEY=
# MinerU 请求超时时间（秒），默认 300 秒（大文件解析需要较长时间）
MINERU_TIMEOUT=300
# MinerU 解析后端（可选）
# - pipeline: 通用，支持多语言，无幻觉
# - vlm-auto-engine: 本地高精度，仅支持中英文
# - hybrid-auto-engine: 新一代本地高精度，支持多语言（默认）
# - hybrid-http-client/vlm-http-client: 远程计算高精度
MINERU_BACKEND=hybrid-auto-engine

# ============================================
# Mastra AI Configuration (推荐使用)
# ============================================

# 阿里云 DashScope / Alibaba API Key
# Mastra 会自动通过 models.dev gateway 路由到对应供应商
# 支持模型: alibaba/qwen3-max, alibaba/qwen3.6-plus 等
ALIBABA_API_KEY=sk-xxx
# 或者使用 DASHSCOPE_API_KEY（两者任选其一）
# DASHSCOPE_API_KEY=sk-xxx

# 可选：其他模型供应商
# OPENAI_API_KEY=sk-...        # OpenAI
# ANTHROPIC_API_KEY=sk-ant-... # Anthropic Claude
# GOOGLE_API_KEY=...           # Google Gemini

# Legacy AI / LangChain (旧版 AI 审查，已弃用)
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=smart-tender-review

# Redis (optional, for queue mode)
REDIS_URL=redis://localhost:6379

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

ENABLE_CRON_IN_DEV=true